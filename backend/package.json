{
  "name": "sarego-backend",
  "version": "0.1.0",
  "description": "SAREGO platform API — Southern Africa Regional Economic Growth Office",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
