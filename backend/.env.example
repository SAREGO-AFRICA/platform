# SAREGO backend environment
# Copy to .env and fill in values

NODE_ENV=development
PORT=4000

# Postgres connection
DATABASE_URL=postgresql://sarego:sarego@localhost:5432/sarego

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
